#!/bin/sh

if ! [ -f /sys/class/power_supply/BAT0/charge_now ]; then
    exit 1
fi

INTERVAL=5

print_icon() {
    STATUS=$(cat /sys/class/power_supply/BAT0/status)

    # percentage=$(acpi | awk -F ', ' '{print $2}')
    percentage=$(cat /sys/class/power_supply/BAT0/capacity)
    percentage=${percentage%"%"}

    if [ "$STATUS" = Full ]; then
        icon=ůĪüĘ
        icon_color='#aaffaa' 
    elif [ "$STATUS" = Charging ]; then
        icon_color='#aaaaff'
        case $((percentage / 10)) in
            0) icon=ůįĘü ;;
            1) icon=ůįĘú ;;
            2) icon=ůįāÜ ;;
            3) icon=ůįāá ;;
            4) icon=ůįāą ;;
            5) icon=ůįĘĚ ;;
            6) icon=ůįāČ ;;
            7) icon=ůįĘě ;;
            8) icon=ůįāä ;;
            9) icon=ůįāč ;;
            10) icon=ůįāĄ
                icon_color='#aaffaa'
                ;;
        esac
    else
        case $((percentage / 10)) in
            0) icon=ůįāé
                icon_color='#ffaaaa'
                ;;
            1) icon=ůįĀļ ;;
            2) icon=ůįĀĽ ;;
            3) icon=ůįĀľ ;;
            4) icon=ůįĀĹ ;;
            5) icon=ůįĀĺ ;;
            6) icon=ůįĀŅ ;;
            7) icon=ůįāÄ ;;
            8) icon=ůįāĀ ;;
            9) icon=ůįāā ;;
            10) icon=ůĪüĘ
                icon_color='#aaffaa'
                ;;
        esac
    fi
    if [ -n "$icon_color" ]; then
        icon='<span color="'$icon_color'">'$icon'</span>'
    fi

    echo $icon $percentage%
}

print_icon

while read button; do
    if [ "$button" ]; then
        notify-send -h "int:value:$percentage" \
            -a "$icon Battery" \
            -c battery-$STATUS \
            -t 7500 "$(acpi | cut -d ' ' -f 3-)"
    fi
done &

while sleep $INTERVAL; do
    print_icon
done
