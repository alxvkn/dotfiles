# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks


# Global properties
separator=true
separator_block_width=15

[sway/window]
command=$SCRIPT_DIR/sway/window
interval=persist

[playerctl]
command=$SCRIPT_DIR/playerctl
interval=persist
markup=pango

[quicknote]
LABEL=ÔČČ
command=$SCRIPT_DIR/quicknote
interval=persist
markup=pango

[adb#phone]
DEVICE_PATTERN=RMX3890
LABEL=ůįĄú
command=$SCRIPT_DIR/adb
interval=persist
markup=pango

[stats]
SEP= | 
LABEL=Ó¨É
MEM_LABEL=ůįėö
STORAGE_LABEL=ůįčä
command=$SCRIPT_DIR/stats
interval=persist

[gnome_dark_mode]
command=$SCRIPT_DIR/gnome_dark_mode
min_width=ÔĒĘ
interval=persist

[network]
command=$SCRIPT_DIR/network
interval=persist

[sensors#cpu]
command=$SCRIPT_DIR/sensors
interval=persist

[battery]
command=$SCRIPT_DIR/battery
interval=5
markup=pango

[pulseaudio]
command=$SCRIPT_DIR/pulseaudio
interval=persist
format=json
markup=pango

[sway/keyboard_layout]
command=$SCRIPT_DIR/sway/keyboard_layout
interval=persist

[date]
command=[ "$button" ] && notify-send -t 20000 -c calendar -a Date "$(date '+%A %d.%m.%Y')" "$(cal)"; date +'ůįÉ≠ %a %x'
interval=1

[time]
command=echo $(clock_icon_from_hour $(date +%k)) $(date +'%H:%M')
interval=1

[sway/scratchpad]
full_text=ůįĖ≤
command=swaymsg scratchpad show > /dev/null 2>&1

